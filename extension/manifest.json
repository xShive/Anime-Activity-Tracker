{
    "manifest_version": 3,
    "name": "AniPresence",
    "version": "1.4.0",
    "description": "Share your anime / manga activity on Discord!",

    "icons": {
        "128": "icon.png"
    },

    "permissions": [
        "tabs"
    ],

    "host_permissions": [
        "https://www.miruro.tv/*",
        "https://www.miruro.bz/*",
        "https://www.miruro.to/*",
        "https://www.miruro.ru/*",
        "https://www.crunchyroll.com/*",
        "https://crunchyroll.com/*",
        "https://animepahe.pw/*",
        "https://kwik.cx/*",
        "http://127.0.0.1:5001/*"
    ],

    "background": {
        "service_worker": "background.js"
    },

    "action": {
        "default_icon": "icon.png",
        "default_popup": "dashboard.html"
    },

    "content_scripts": [
        {
            "matches": ["https://www.miruro.tv/*", "https://www.miruro.bz/*", "https://www.miruro.to/*", "https://www.miruro.ru/*", "https://www.crunchyroll.com/*", "https://crunchyroll.com/*", "https://animepahe.pw/*"],
            "js": ["config.js", "content.js"]
        },
        {
            "matches": ["https://kwik.cx/*"],
            "js": ["kwik.js"],
            "all_frames": true
        }
    ]
}