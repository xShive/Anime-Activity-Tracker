{
    "manifest_version": 3,
    "name": "Anime Activity Tracker",
    "version": "1.0",
    "description": "Shows what anime you're watching on Discord",

    "icons": {
        "128": "icon.png"
    },

    "host_permissions": [
        "https://www.miruro.tv/*",
        "http://127.0.0.1:5001/*"
    ],

    "content_scripts": [
    {
        "matches": ["https://www.miruro.tv/*"],
        "js": ["config.js", "content.js"]
    }
    ]
}