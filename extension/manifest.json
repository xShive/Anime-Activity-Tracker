{
    "manifest_version": 3,
    "name": "AniPresence",
    "version": "1.3.2",
    "description": "Share your anime / manga activity on Discord!",

    "icons": {
        "128": "icon.png"
    },

    "permissions": [
        "tabs"
    ],

    "host_permissions": [
        "https://www.miruro.tv/*",
        "https://www.miruro.bz/*",
        "https://www.miruro.to/*",
        "https://www.miruro.ru/*",
        "https://www.crunchyroll.com/*",
        "https://crunchyroll.com/*",
        "http://127.0.0.1:5001/*"
    ],

    "background": {
        "service_worker": "background.js"
    },

    "action": {
        "default_icon": "icon.png"
    },

    "content_scripts": [
    {
        "matches": ["https://www.miruro.tv/*", "https://www.miruro.bz/*", "https://www.miruro.to/*", "https://www.miruro.ru/*", "https://www.crunchyroll.com/*", "https://crunchyroll.com/*"],
        "js": ["config.js", "content.js"]
    }
    ]
}